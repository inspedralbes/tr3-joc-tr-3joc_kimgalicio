# .env.example
# Còpia aquest fitxer com ".env" i omple els valors reals.
# Mai pujis el fitxer .env al repositori (ja està al .gitignore).

# Adreça del servidor MySQL (normalment 'localhost' en local)
DB_HOST=localhost

# Usuari de MySQL amb permisos sobre ticktack_tag
DB_USER=root

# Contrasenya de l'usuari de MySQL
DB_PASSWORD=

# Nom de la base de dades creada amb database.sql
DB_NAME=ticktack_tag
